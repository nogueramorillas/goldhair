# Puerto del servidor
PORT=3000

# Directorio de datos persistente (Railway: /data)
DATA_DIR=./data

# Secreto de sesión - CAMBIA ESTO
SESSION_SECRET=cambia-esto-por-algo-seguro

# Gmail para envío de confirmaciones
GMAIL_USER=tucorreo@gmail.com
GMAIL_APP_PASSWORD=tu-app-password-de-gmail

# Twilio para SMS de verificación antes de reservar (opcional: sin esto, no se envían SMS)
TWILIO_ACCOUNT_SID=tu-account-sid
TWILIO_AUTH_TOKEN=tu-auth-token
TWILIO_FROM_NUMBER=+1234567890

# Entorno
NODE_ENV=production
